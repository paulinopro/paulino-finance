# Copiar a .env en esta carpeta:  cp env.example .env
# Referencia duplicada en la raíz: ../backend.env.example

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=paulino_finance

# Server Configuration
NODE_ENV=development
PORT=5000

# Opcional: etiqueta de despliegue (GET /admin/health → deployRef)
# RELEASE=1.2.3
# GIT_COMMIT=
# VERCEL_GIT_COMMIT_SHA=
# RAILWAY_GIT_COMMIT_SHA=
# COMMIT_SHA=

# Orígenes CORS permitidos (coma-separados). En producción define el dominio del frontend, ej. https://app.tudominio.com
# Si no se define, CORS permite cualquier origen (solo adecuado en desarrollo).
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Detrás de Nginx/Docker: permite que express-rate-limit use la IP real del cliente
# TRUST_PROXY=true

# Límite de intentos auth (opcional; por defecto depende de NODE_ENV)
# AUTH_LOGIN_MAX_PER_WINDOW=40
# AUTH_REGISTER_MAX_PER_WINDOW=15
# AUTH_FORGOT_PASSWORD_MAX_PER_WINDOW=5
# AUTH_RESET_PASSWORD_MAX_PER_WINDOW=20

# URL pública del frontend (enlaces de recuperación de contraseña). `auth` usa FRONTEND_URL o APP_PUBLIC_URL.
# FRONTEND_URL=http://localhost:3000
# APP_PUBLIC_URL=http://localhost:3000

# SMTP (opcional; sin esto el enlace solo se registra en logs en desarrollo). Ej. Gmail: smtp.gmail.com, puerto 587
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Paulino Finance <noreply@tudominio.com>"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Super admin: comma-separated emails. These users get is_super_admin on DB sync and on register.
# After changing, restart the API so syncSuperAdminsFromEnv runs.
SUPER_ADMIN_EMAILS=admin@example.com
# Guía operación consola / webhooks: ../docs/Operacion_Super_Admin.md

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Exchange Rate (DOP to USD)
EXCHANGE_RATE_DOP_USD=65

# PayPal (suscripciones). Opción A: POST /api/admin/subscription-plans/:id/sync-paypal (super admin) crea producto + planes mensual/anual en PayPal y guarda PROD- / P- en BD. Opción B: crear en el dashboard PayPal y pegar los IDs en el plan.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox: https://api-m.sandbox.paypal.com  |  Producción: https://api-m.paypal.com
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# URLs de retorno tras aprobar o cancelar (deben coincidir con las permitidas en la app PayPal)
PAYPAL_RETURN_URL=http://localhost:3000/subscription
PAYPAL_CANCEL_URL=http://localhost:3000/subscription

# ID del webhook creado en PayPal Developer (Webhooks) — obligatorio para verificar firmas en producción
# PAYPAL_WEBHOOK_ID=

# Solo desarrollo: omitir verificación de firma (nunca en producción)
# PAYPAL_SKIP_WEBHOOK_VERIFY=true

# Web Push (PWA). Generar: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:soporte@tudominio.com
