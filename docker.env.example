# Variables para Docker Compose (archivo .env en la RAÍZ del repositorio).
# Uso:  cp docker.env.example .env
# Compose inyecta estas variables en docker-compose.yml (Postgres, puertos, JWT, Telegram, REACT_APP_*).
# El contenedor del backend recibe DB_HOST=postgres desde el compose (no hace falta ponerlo aquí).

# --- PostgreSQL (servicio postgres + credenciales del backend) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=paulino_finance

# --- Puertos en el host ---
BACKEND_PORT=5000
FRONTEND_PORT=3000

NODE_ENV=development

# Opcional: revisión desplegada (GET /admin/health → deployRef; se usa la primera que exista)
# RELEASE=1.2.3
# GIT_COMMIT=
# VERCEL_GIT_COMMIT_SHA=
# RAILWAY_GIT_COMMIT_SHA=
# COMMIT_SHA=

# URL pública del frontend (mismo host/puerto que abre el usuario en el navegador). Obligatoria en producción para enlaces de correo (recuperación de contraseña).
# En local con Compose: suele coincidir con http://localhost:${FRONTEND_PORT}
# FRONTEND_URL=http://localhost:3000
# APP_PUBLIC_URL=http://localhost:3000

# Orígenes permitidos para CORS (coma-separados). Si no defines, el API puede permitir cualquier origen solo en desarrollo.
# CORS_ORIGIN=http://localhost:3000

# --- Backend (JWT obligatorio en producción) ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Tasa DOP por 1 USD (default del sistema y registro; cada usuario puede sobrescribir en Ajustes)
EXCHANGE_RATE_DOP_USD=65

# Opcional: recordatorios por Telegram
TELEGRAM_BOT_TOKEN=

# Web Push PWA (mismas claves que en backend/.env o raíz; generar: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:soporte@tudominio.com

# --- Frontend (navegador del usuario llama al API) ---
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENABLE_PWA=true
# Opcional: permitir suscripción push en dev (requiere VAPID en backend arriba)
# REACT_APP_ENABLE_PUSH_SYNC=true

# --- PayPal (obligatorio para Sincronizar PayPal / suscripciones; mismo .env que en la raíz) ---
# Copia estas claves a tu .env en la raíz del repo (Compose las inyecta al backend).
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# PAYPAL_RETURN_URL=http://localhost:3000/subscription
# PAYPAL_CANCEL_URL=http://localhost:3000/subscription
# PAYPAL_WEBHOOK_ID=

# SUPER_ADMIN_EMAILS=admin@example.com

# SMTP u otras claves del backend: añade en .env raíz y, si no está en docker-compose.yml → backend.environment, amplía el servicio.
