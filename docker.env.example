# Variables para Docker Compose (archivo .env en la RAÍZ del repositorio).
# Uso:  cp docker.env.example .env
# Compose inyecta estas variables en docker-compose.yml (Postgres, puertos, JWT, Telegram, REACT_APP_*).
# El contenedor del backend recibe DB_HOST=postgres desde el compose (no hace falta ponerlo aquí).

# --- PostgreSQL (servicio postgres + credenciales del backend) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=paulino_finance

# --- Puertos en el host ---
BACKEND_PORT=5000
FRONTEND_PORT=3000

NODE_ENV=development

# --- Backend (JWT obligatorio en producción) ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Opcional: recordatorios por Telegram
TELEGRAM_BOT_TOKEN=

# --- Frontend (navegador del usuario llama al API) ---
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENABLE_PWA=true

# CORS, SMTP, PayPal, SUPER_ADMIN_EMAILS, etc.: amplía docker-compose.yml
# para pasar más env al servicio backend, o usa backend.env.example como referencia.
