# Copia a .env.production antes de npm run build si el backend NO está en el mismo dominio bajo /api
# Ejemplo: API en otro subdominio
# REACT_APP_API_URL=https://api.finance.paulino.pro/api

# Si nginx en el mismo dominio hace proxy de /api al backend, puedes omitir esta variable
# (el cliente usará automáticamente https://TU_DOMINIO/api).

# Opcional: en desarrollo local, sincronizar suscripción push con el API (requiere PWA + VAPID en backend)
# REACT_APP_ENABLE_PUSH_SYNC=true
