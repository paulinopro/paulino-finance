# Copiar a .env en esta carpeta:  cp env.example .env
# Referencia duplicada en la raíz: ../frontend.env.example

REACT_APP_API_URL=http://localhost:5000/api
# En producción, desactivar solo si no quieres registrar el service worker (build)
REACT_APP_ENABLE_PWA=true
# og:image / twitter:image en index.html usan %PUBLIC_URL%/icon-512.png (ruta relativa al dominio).
# Algunos rastreadores prefieren URL absoluta; en ese caso sirve el mismo icono desde tu dominio público.
